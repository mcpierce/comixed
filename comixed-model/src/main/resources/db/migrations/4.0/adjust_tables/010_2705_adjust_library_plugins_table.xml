<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">
    <changeSet id="010_2705_adjust_library_plugins_table.xml" author="mcpierce">

        <preConditions onFail="MARK_RAN">
            <tableExists tableName="library_plugins"/>
        </preConditions>

        <dropForeignKeyConstraint baseTableName="library_plugin_properties"
                                  constraintName="library_plugin_properties_v3_library_plugin_fk"/>

        <renameTable oldTableName="library_plugins" newTableName="old_library_plugins"/>

        <createTable tableName="library_plugins_v4">
            <column name="library_plugin_id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="library_plugins_v4_pk"/>
            </column>

            <column name="name" type="varchar(64)">
                <constraints nullable="false"/>
            </column>

            <column name="unique_name" type="varchar(64)">
                <constraints nullable="false" unique="true" uniqueConstraintName="library_plugins_v4_unique_name"/>
            </column>

            <column name="language" type="varchar(32)">
                <constraints nullable="false"/>
            </column>

            <column name="filename" type="varchar(1024)">
                <constraints nullable="false"/>
            </column>

            <column name="admin_only" type="boolean">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <sql>INSERT INTO library_plugins_v4(library_plugin_id, name, unique_name, language, filename,
                                            admin_only)
             SELECT library_plugin_id,
                    name,
                    unique_name, language, filename, admin_only
             FROM old_library_plugins</sql>

        <sql dbms="postgresql">
            SELECT SETVAL((SELECT PG_GET_SERIAL_SEQUENCE('"library_plugins_v4"', 'library_plugin_id')),
                          (SELECT (MAX("library_plugin_id") + 1) FROM "library_plugins_v4"), FALSE);
        </sql>

        <dropTable tableName="old_library_plugins"/>

    </changeSet>
</databaseChangeLog>
