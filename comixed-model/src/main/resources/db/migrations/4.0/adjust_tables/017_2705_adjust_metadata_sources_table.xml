<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">
    <changeSet id="017_2705_adjust_metadata_sources_table.xml" author="mcpierce">

        <preConditions onFail="MARK_RAN">
            <tableExists tableName="metadata_sources"/>
        </preConditions>

        <dropForeignKeyConstraint baseTableName="comic_metadata_sources"
                                  constraintName="comic_metadata_source_metadata_source_fk"/>
        <dropForeignKeyConstraint baseTableName="scraped_stories"
                                  constraintName="scraped_story_metadata_source_fk"/>

        <renameTable oldTableName="metadata_sources" newTableName="old_metadata_sources"/>

        <createTable tableName="metadata_sources_v4">
            <column name="metadata_source_id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="metadata_sources_v4_pk"/>
            </column>

            <column name="adaptor_name" type="varchar(255)">
                <constraints nullable="false" unique="true" uniqueConstraintName="metadata_sources_v4_unique_adaptor_name"/>
            </column>

            <column name="preferred_source" type="boolean" defaultValue="false">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <sql>INSERT INTO metadata_sources_v4(metadata_source_id, adaptor_name, preferred_source)
             SELECT metadata_source_id, adaptor_name, preferred_source
             FROM old_metadata_sources</sql>

        <sql dbms="postgresql">
            SELECT SETVAL((SELECT PG_GET_SERIAL_SEQUENCE('"metadata_sources_v4"', 'metadata_source_id')),
                          (SELECT (MAX("metadata_source_id") + 1) FROM "metadata_sources_v4"), FALSE);
        </sql>

        <dropTable tableName="old_metadata_sources"/>

    </changeSet>
</databaseChangeLog>
