<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">
    <changeSet id="003_2705_adjust_comixed_roles_table.xml" author="mcpierce">

        <preConditions onFail="MARK_RAN">
            <tableExists tableName="comixed_roles"/>
        </preConditions>

        <renameTable oldTableName="comixed_roles" newTableName="old_comixed_roles"/>

        <dropForeignKeyConstraint baseTableName="comixed_user_roles"
                                  constraintName="comixed_user_role_comixed_role_fk"/>

        <createTable tableName="comixed_roles_v4">
            <column name="comixed_role_id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="comixed_roles_v4_pk"/>
            </column>

            <column name="name" type="varchar(32)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="comixed_roles_v4" columnNames="name"
                             constraintName="comixed_roles_v4_unique_name"/>

        <sql>INSERT INTO comixed_roles_v4(comixed_role_id, name)
             SELECT comixed_role_id, name
             FROM old_comixed_roles</sql>

        <sql dbms="postgresql">
            SELECT SETVAL((SELECT PG_GET_SERIAL_SEQUENCE('"comixed_roles_v4"', 'comixed_role_id')),
                          (SELECT (MAX("comixed_role_id") + 1) FROM "comixed_roles_v4"), FALSE);
        </sql>

        <dropTable tableName="old_comixed_roles"/>

    </changeSet>
</databaseChangeLog>
