<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">
    <changeSet id="015_2705_adjust_metadata_cache_table.xml" author="mcpierce">

        <preConditions onFail="MARK_RAN">
            <tableExists tableName="metadata_cache"/>
        </preConditions>

        <renameTable oldTableName="metadata_cache" newTableName="old_metadata_cache"/>

        <createTable tableName="metadata_cache_v4">
            <column name="metadata_cache_id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="metadata_cache_v4_pk"/>
            </column>

            <column name="metadata_source" type="varchar(32)">
                <constraints nullable="false"/>
            </column>

            <column name="cache_key" type="varchar(256)">
                <constraints nullable="false"/>
            </column>

            <column name="created_on" type="datetime">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="metadata_cache_v4" indexName="metadata_cache_v4_source_and_cache_key_idx">
            <column name="metadata_source"/>
            <column name="cache_key"/>
        </createIndex>

        <addUniqueConstraint tableName="metadata_cache_v4"
                             constraintName="metadata_cache_v4_unique_metadata_source_and_cache_key"
                             columnNames="metadata_source, cache_key"/>

        <sql>INSERT INTO metadata_cache_v4(metadata_cache_id, metadata_source, cache_key, created_on)
             SELECT metadata_cache_id, metadata_source, cache_key, created_on
             FROM old_metadata_cache</sql>

        <sql dbms="postgresql">
            SELECT SETVAL((SELECT PG_GET_SERIAL_SEQUENCE('"metadata_cache_v4"', 'metadata_cache_id')),
                          (SELECT (MAX("metadata_cache_id") + 1) FROM "metadata_cache_v4"), FALSE);
        </sql>

        <dropTable tableName="old_metadata_cache"/>

    </changeSet>
</databaseChangeLog>
