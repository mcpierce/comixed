<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">
    <changeSet id="021_2705_adjust_reading_lists_table.xml" author="mcpierce">

        <preConditions onFail="MARK_RAN">
            <tableExists tableName="reading_lists"/>
        </preConditions>

        <dropForeignKeyConstraint baseTableName="reading_list_entries"
                                  constraintName="reading_list_entry_reading_list_fk"/>

        <renameTable oldTableName="reading_lists" newTableName="old_reading_lists"/>

        <createTable tableName="reading_lists_v4">
            <column name="reading_list_id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="reading_lists_v4_pk"/>
            </column>

            <column name="owner_id" type="bigint">
                <constraints nullable="false"/>
            </column>

            <column name="reading_list_name" type="varchar(128)">
                <constraints nullable="false"/>
            </column>

            <column name="last_modified_on" type="datetime">
                <constraints nullable="false"/>
            </column>

            <column name="summary" type="varchar(256)">
                <constraints nullable="false"/>
            </column>

            <column name="created_on" type="datetime">
                <constraints nullable="false"/>
            </column>

            <column name="reading_list_state" type="varchar(32)">
                <constraints nullable="false"/>
            </column>

            <column name="name_key" type="varchar(128)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="reading_lists_v4" baseColumnNames="owner_id"
                                 constraintName="reading_lists_v4_owner_fk"
                                 referencedTableName="comixed_users_v4"
                                 referencedColumnNames="comixed_user_id"/>

        <addUniqueConstraint tableName="reading_lists_v4" columnNames="owner_id, name_key"
                             constraintName="reading_list_v4_unique_owner_name"/>

        <sql>INSERT INTO reading_lists_v4(reading_list_id, owner_id, reading_list_name, last_modified_on, summary,
                                          created_on, reading_list_state, name_key)
             SELECT reading_list_id,
                    owner_id,
                    reading_list_name,
                    last_modified_on,
                    summary,
                    created_on,
                    reading_list_state,
                    name_key
             FROM old_reading_lists</sql>

        <sql dbms="postgresql">
            SELECT SETVAL((SELECT PG_GET_SERIAL_SEQUENCE('"reading_lists_v4"', 'reading_list_id')),
                          (SELECT (MAX("reading_list_id") + 1) FROM "reading_lists_v4"), FALSE);
        </sql>

        <dropTable tableName="old_reading_lists"/>

    </changeSet>
</databaseChangeLog>
