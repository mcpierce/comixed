<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">
    <changeSet id="018_2705_adjust_metadata_source_properties_table.xml" author="mcpierce">

        <preConditions onFail="MARK_RAN">
            <tableExists tableName="metadata_source_properties"/>
        </preConditions>

        <renameTable oldTableName="metadata_source_properties" newTableName="old_metadata_source_properties"/>

        <createTable tableName="metadata_source_properties_v4">
            <column name="metadata_source_property_id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="metadata_source_properties_v4_pk"/>
            </column>

            <column name="metadata_source_id" type="bigint">
                <constraints nullable="false"/>
            </column>

            <column name="property_name" type="varchar(32)">
                <constraints nullable="false" unique="true" uniqueConstraintName="metadata_source_properties_v4_unique_property_name"/>
            </column>

            <column name="property_value" type="varchar(256)">
                <constraints nullable="true"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="metadata_source_properties_v4" baseColumnNames="metadata_source_id"
                                 constraintName="metadata_source_properties_v4_metadata_source_fk"
                                 referencedTableName="metadata_sources_v4"
                                 referencedColumnNames="metadata_source_id"/>

        <createIndex tableName="metadata_source_properties_v4" indexName="metadata_source_properties_v4_source_idx">
            <column name="metadata_source_id"/>
        </createIndex>

        <sql>INSERT INTO metadata_source_properties_v4(metadata_source_property_id, metadata_source_id, property_name,
                                                       property_value)
             SELECT metadata_source_property_id, metadata_source_id, property_name, property_value
             FROM old_metadata_source_properties</sql>

        <sql dbms="postgresql">
            SELECT SETVAL((SELECT PG_GET_SERIAL_SEQUENCE('"metadata_source_properties_v4"',
                                                         'metadata_source_property_id')),
                          (SELECT (MAX("metadata_source_property_id") + 1) FROM "metadata_source_properties_v4"), FALSE);
        </sql>

        <dropTable tableName="old_metadata_source_properties"/>

    </changeSet>
</databaseChangeLog>
