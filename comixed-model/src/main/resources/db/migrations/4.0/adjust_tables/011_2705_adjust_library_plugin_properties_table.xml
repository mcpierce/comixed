<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">
    <changeSet id="011_2705_adjust_library_plugin_properties_table.xml" author="mcpierce">

        <preConditions onFail="MARK_RAN">
            <tableExists tableName="library_plugin_properties"/>
        </preConditions>

        <renameTable oldTableName="library_plugin_properties" newTableName="old_library_plugin_properties"/>

        <createTable tableName="library_plugin_properties_v4">
            <column name="library_plugin_property_id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="library_plugin_properties_v4_pk"/>
            </column>

            <column name="library_plugin_id" type="bigint">
                <constraints nullable="false"/>
            </column>

            <column name="property_name" type="varchar(32)">
                <constraints nullable="false"/>
            </column>

            <column name="property_length" type="int">
                <constraints nullable="false"/>
            </column>

            <column name="property_default_value" type="varchar(128)">
                <constraints nullable="true"/>
            </column>

            <column name="property_required" type="boolean">
                <constraints nullable="false"/>
            </column>

            <column name="property_value" type="varchar(128)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="library_plugin_properties_v4"
                                 baseColumnNames="library_plugin_property_id"
                                 constraintName="library_plugin_properties_v4_library_plugin_fk"
                                 referencedTableName="library_plugins_v4"
                                 referencedColumnNames="library_plugin_id"/>

        <addUniqueConstraint tableName="library_plugin_properties_v4"
                             constraintName="library_plugin_properties_v4_unique_plugin_and_name"
                             columnNames="library_plugin_id, property_name"/>

        <sql>INSERT INTO library_plugin_properties_v4(library_plugin_property_id, library_plugin_id, property_name,
                                                      property_length, property_default_value, property_required,
                                                      property_value)
             SELECT library_plugin_property_id,
                    library_plugin_id,
                    property_name,
                    property_length,
                    property_default_value,
                    property_required,
                    property_value
             FROM old_library_plugin_properties</sql>

        <sql dbms="postgresql">
            SELECT SETVAL((SELECT PG_GET_SERIAL_SEQUENCE('"library_plugin_properties_v4"',
                                                         'library_plugin_property_id')),
                          (SELECT (MAX("library_plugin_property_id") + 1) FROM "library_plugin_properties_v4"), FALSE);
        </sql>

        <dropTable tableName="old_library_plugin_properties"/>

    </changeSet>
</databaseChangeLog>
