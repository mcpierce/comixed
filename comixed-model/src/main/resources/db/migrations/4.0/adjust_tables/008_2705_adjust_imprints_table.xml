<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">
    <changeSet id="008_2705_adjust_imprints_table.xml" author="mcpierce">

        <preConditions onFail="MARK_RAN">
            <tableExists tableName="imprints"/>
        </preConditions>

        <renameTable oldTableName="imprints" newTableName="old_imprints"/>

        <createTable tableName="imprints_v4">
            <column name="imprint_id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="imprints_v4_pk"/>
            </column>

            <column name="imprint_name" type="varchar(128)">
                <constraints nullable="false" unique="true" uniqueConstraintName="imprints_v4_unique_imprint_name"/>
            </column>

            <column name="publisher" type="varchar(128)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <sql>INSERT INTO imprints_v4(imprint_id, imprint_name, publisher)
             SELECT imprint_id, imprint_name, publisher
             FROM old_imprints</sql>

        <sql dbms="postgresql">
            SELECT SETVAL((SELECT PG_GET_SERIAL_SEQUENCE('"imprints_v4"', 'imprint_id')),
                          (SELECT (MAX("imprint_id") + 1) FROM "imprints_v4"), FALSE);
        </sql>

        <dropTable tableName="old_imprints"/>

    </changeSet>
</databaseChangeLog>
