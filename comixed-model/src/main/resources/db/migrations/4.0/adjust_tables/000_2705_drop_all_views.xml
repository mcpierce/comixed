<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">
    <changeSet id="000_2705_drop_all_views.xml" author="mcpierce">

        <preConditions onFail="MARK_RAN">
            <viewExists viewName="collections_view"/>
            <viewExists viewName="displayable_comics_view"/>
            <viewExists viewName="duplicate_comics_view"/>
            <viewExists viewName="duplicate_pages_view"/>
            <viewExists viewName="organizing_comics_view"/>
            <viewExists viewName="publisher_details_view"/>
            <viewExists viewName="series_details_view"/>
            <viewExists viewName="stories_view"/>
        </preConditions>

        <dropView viewName="collections_view"/>
        <dropView viewName="displayable_comics_view"/>
        <dropView viewName="duplicate_comics_view"/>
        <dropView viewName="duplicate_pages_view"/>
        <dropView viewName="organizing_comics_view"/>
        <dropView viewName="publisher_details_view"/>
        <dropView viewName="series_details_view"/>
        <dropView viewName="stories_view"/>

    </changeSet>
</databaseChangeLog>
