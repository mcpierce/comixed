<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">
    <changeSet id="016_2705_adjust_metadata_cache_entries_table.xml" author="mcpierce">

        <preConditions onFail="MARK_RAN">
            <tableExists tableName="metadata_cache_entries"/>
        </preConditions>

        <renameTable oldTableName="metadata_cache_entries" newTableName="old_metadata_cache_entries"/>

        <createTable tableName="metadata_cache_entries_v4">
            <column name="metadata_cache_entry_id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="metadata_cache_entries_v4_pk"/>
            </column>

            <column name="metadata_cache_id" type="bigint">
                <constraints nullable="false"/>
            </column>

            <column name="entry_number" type="int">
                <constraints nullable="false"/>
            </column>

            <column name="entry_value" type="clob">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="metadata_cache_entries_v4" baseColumnNames="metadata_cache_id"
                                 constraintName="metadata_cache_entries_v4_metadata_cache_fk"
                                 referencedTableName="metadata_cache_v4"
                                 referencedColumnNames="metadata_cache_id"/>

        <addUniqueConstraint tableName="metadata_cache_entries_v4"
                             constraintName="metadata_cache_entries_v4_unique_cache_and_entry_number"
                             columnNames="metadata_cache_id, entry_number"/>

        <sql>INSERT INTO metadata_cache_entries_v4(metadata_cache_id, entry_number, entry_value)
             SELECT metadata_cache_id, entry_number, entry_value
             FROM old_metadata_cache_entries</sql>

        <sql dbms="postgresql">
            SELECT SETVAL((SELECT PG_GET_SERIAL_SEQUENCE('"metadata_cache_entries_v4"', 'metadata_cache_entry_id')),
                          (SELECT (MAX("metadata_cache_entry_id") + 1) FROM "metadata_cache_entries_v4"), FALSE);
        </sql>

        <dropTable tableName="old_metadata_cache_entries"/>

    </changeSet>
</databaseChangeLog>
