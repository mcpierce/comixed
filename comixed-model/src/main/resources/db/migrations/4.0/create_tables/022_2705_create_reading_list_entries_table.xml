<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">
    <changeSet id="022_2705_create_reading_list_entries_table.xml" author="mcpierce">

        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="reading_list_entries_v4"/>
            </not>
        </preConditions>

        <createTable tableName="reading_list_entries_v4">
            <column name="reading_list_entry_id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="reading_list_entries_v4_pk"/>
            </column>

            <column name="reading_list_id" type="bigint">
                <constraints nullable="false"/>
            </column>

            <column name="comic_detail_id" type="bigint">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="reading_list_entries_v4" baseColumnNames="reading_list_id"
                                 constraintName="reading_list_entries_v4_reading_list_fk"
                                 referencedTableName="reading_lists_v4"
                                 referencedColumnNames="reading_list_id"/>

        <addUniqueConstraint tableName="reading_list_entries_v4"
                             columnNames="reading_list_id, comic_detail_id"
                             constraintName="reading_list_entries_v4_unique_reading_list_and_comic_details"/>

    </changeSet>
</databaseChangeLog>
