<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">
    <changeSet id="021_2705_create_reading_lists_table.xml" author="mcpierce">

        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="reading_lists_v4"/>
            </not>
        </preConditions>

        <createTable tableName="reading_lists_v4">
            <column name="reading_list_id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="reading_lists_v4_pk"/>
            </column>

            <column name="owner_id" type="bigint">
                <constraints nullable="false"/>
            </column>

            <column name="reading_list_name" type="varchar(128)">
                <constraints nullable="false"/>
            </column>

            <column name="last_modified_on" type="datetime">
                <constraints nullable="false"/>
            </column>

            <column name="summary" type="varchar(256)">
                <constraints nullable="false"/>
            </column>

            <column name="created_on" type="datetime">
                <constraints nullable="false"/>
            </column>

            <column name="reading_list_state" type="varchar(32)">
                <constraints nullable="false"/>
            </column>

            <column name="name_key" type="varchar(128)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="reading_lists_v4" baseColumnNames="owner_id"
                                 constraintName="reading_lists_v4_owner_fk"
                                 referencedTableName="comixed_users_v4"
                                 referencedColumnNames="comixed_user_id"/>

        <addUniqueConstraint tableName="reading_lists_v4" columnNames="owner_id, name_key"
                             constraintName="reading_list_v4_unique_owner_name"/>

    </changeSet>
</databaseChangeLog>
